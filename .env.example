# Configuración de Firebase - Ejemplo de variables necesarias
# Copia este archivo a .env.local y completa con tus credenciales

NEXT_PUBLIC_FIREBASE_API_KEY=tu_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=fastpage2-db56b.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=fastpage2-db56b
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=fastpage2-db56b.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=tu_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=tu_app_id
# Dominios permitidos para usar como authDomain (same-origin recomendado en PWA/mobile)
NEXT_PUBLIC_FIREBASE_AUTH_ALLOWED_DOMAINS=www.fastpagepro.com,fastpagepro.com,fastpage-7ceb3.firebaseapp.com,fastpage-7ceb3.web.app,localhost,127.0.0.1
# Forzar authDomain same-origin (0 recomendado para evitar redirect_uri_mismatch en hosts no configurados)
NEXT_PUBLIC_FIREBASE_AUTH_FORCE_SAME_ORIGIN=0

# Dominio canonico para autenticacion web (OAuth)
NEXT_PUBLIC_AUTH_CANONICAL_HOST=www.fastpagepro.com
# Alias separados por coma que deben redirigir al canonico
NEXT_PUBLIC_AUTH_ALIAS_HOSTS=fastpagepro.com
# Fuerza Google Auth por redirect (recomendado para evitar bloqueos de popup/extensiones)
# 1 = redirect siempre, 0 = permitir popup en desktop
NEXT_PUBLIC_GOOGLE_AUTH_FORCE_REDIRECT=0

# Dominio base para cookies de sesion de suscripcion (apex + www)
SUBSCRIPTION_COOKIE_BASE_DOMAINS=fastpagepro.com

# Opcional para Admin SDK
FIREBASE_SERVICE_ACCOUNT_KEY={"type": "service_account", ...}

# URL publica base para links de referidos
NEXT_PUBLIC_APP_URL=https://www.fastpagepro.com
# Comision del programa de referidos (%)
REFERRAL_COMMISSION_PERCENT=10

# Izipay checkout (modo mock/live)
IZIPAY_MODE=mock
IZIPAY_API_BASE_URL=
IZIPAY_CHECKOUT_PATH=/v1/payments/checkout
IZIPAY_STATUS_PATH=/v1/payments/{paymentId}
IZIPAY_USERNAME=
IZIPAY_PASSWORD=
IZIPAY_API_KEY=

# Stripe checkout (modo mock/live)
STRIPE_MODE=mock
STRIPE_SECRET_KEY=

# Upstash Redis (opcional, para rate limit server-side en endpoints criticos)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
