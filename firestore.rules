rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function rootAdminEmail() {
      return "afiliadosprobusiness@gmail.com";
    }

    function tokenEmail() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email.lower()
        : "";
    }

    function isAdmin() {
      return signedIn() &&
        (
          request.auth.token.admin == true ||
          tokenEmail() == rootAdminEmail()
        );
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(userId) && request.resource.data.uid == userId)
        || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /cloned_sites/{siteId} {
      allow get, list: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update: if (isAdmin() || (signedIn() && resource.data.userId == request.auth.uid))
        && request.resource.data.userId == resource.data.userId;

      allow delete: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /link_profiles/{profileId} {
      function isLinkProfileOwner() {
        return signedIn()
          && (
            profileId == request.auth.uid
            || resource.data.userId == request.auth.uid
          );
      }

      allow get: if isAdmin()
        || isLinkProfileOwner()
        || resource.data.published == true;

      allow list: if isAdmin()
        || resource.data.published == true
        || (signedIn() && (
          profileId == request.auth.uid
          || resource.data.userId == request.auth.uid
        ));

      allow create: if signedIn()
        && profileId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      allow update: if isAdmin()
        || (
          isLinkProfileOwner()
          && request.resource.data.userId == request.auth.uid
        );

      allow delete: if isAdmin() || isLinkProfileOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
